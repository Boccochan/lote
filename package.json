{
  "name": "lote",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig-app.json && tsc -p tsconfig-node.json",
    "lint": "eslint .",
    "test": "vitest run --project=unit",
    "test:watch": "vitest --project=unit",
    "test:storybook": "vitest run --project=storybook",
    "lint:rust": "cd src-tauri && cargo clippy --all-targets",
    "fmt:rust": "cd src-tauri && cargo fmt --all",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "e2e:tauri:install-driver": "node e2e-tauri/scripts/install-msedgedriver.mjs",
    "e2e:tauri:capture": "npm run e2e:tauri:install-driver && wdio run e2e-tauri/wdio.conf.js && node e2e-tauri/scripts/stitch-captures.mjs",
    "pr:attach-captures": "node e2e-tauri/scripts/attach-pr-media.mjs",
    "e2e:tauri:capture:publish": "npm run e2e:tauri:capture && npm run pr:attach-captures"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.3.1",
    "@storybook/addon-docs": "^10.3.1",
    "@storybook/addon-vitest": "^10.3.1",
    "@storybook/svelte-vite": "^10.3.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/svelte": "^5.2.8",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@wdio/cli": "^9.19.0",
    "@wdio/local-runner": "^9.19.0",
    "@wdio/mocha-framework": "^9.19.0",
    "@wdio/spec-reporter": "^9.19.0",
    "eslint": "^10.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-storybook": "^10.3.1",
    "eslint-plugin-svelte": "^3.16.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.4.0",
    "jsdom": "^26.0.0",
    "playwright": "^1.58.2",
    "storybook": "^10.3.1",
    "svelte": "^5.53.12",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1"
  }
}
