# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist

# Cargo (root-level alternate target directories)
/target/
/target-agent-test/
dist-ssr
*.local
.eslintcache

